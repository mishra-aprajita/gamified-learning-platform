# ─────────────────────────────────────────────
#  XPify Backend  –  Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# MongoDB Atlas connection string
# Get it from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/levelup?retryWrites=true&w=majority

# JWT secret key – use any long random string
JWT_SECRET=levelup_super_secret_jwt_key_change_this_in_production_2024

# JWT token expiry
JWT_EXPIRE=7d

# Port the server runs on
PORT=5000

# Frontend URL (for CORS) – change to your Vercel URL in production
CLIENT_URL=http://localhost:3000

# Google Sign-In Client ID (optional but recommended)
# Get it from: https://console.cloud.google.com/apis/credentials
# Used to verify that Google login tokens were issued for YOUR app specifically
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# OpenAI API Key — powers Nova's AI chat & daily tips (optional)
# Get it from: https://platform.openai.com/api-keys
# Without this, Nova chat returns a friendly "not configured" message
# and the daily tip falls back to a hardcoded message instead.
OPENAI_API_KEY=sk-your-openai-api-key-here
